db.sqlite3-journal

# --- Cache et fichiers compilés Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyc

# --- Django ---
*.log
local_settings.py
media/
staticfiles/

# --- Éditeurs / IDE / outils ---
.claude/
.vscode/
.idea/
*.swp
*~

# --- Système ---
.DS_Store
Thumbs.db
